{
  "name": "tianwen7252.github.io",
  "version": "2.0.0-alpha",
  "description": "Tianwen App",
  "main": "src/index.tsx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tianwen7252/tianwen7252.github.io.git"
  },
  "author": "Tianwen",
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "oxlint && tsc --noEmit",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write 'src/**/*.{ts,tsx,css}'",
    "format:check": "oxfmt --check 'src/**/*.{ts,tsx,css}'",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "3.51.2-build8",
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.3",
    "@tanstack/react-router": "^1.168.1",
    "@tanstack/react-router-devtools": "^1.166.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.7",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  }
}
